<launch>

  <!-- ═══════════════════════════════════════════════════════════════════════
       YOLOv10 Full Perception Stack (with LiDAR fusion)
       ═══════════════════════════════════════════════════════════════════════
       Launches the complete perception pipeline:
         1. yolov10_detector    — camera → detections
         2. perception_fusion   — LiDAR depth + scoring-topic routing
         3. light_classifier    — EfficientNet B0 traffic light state
         4. sign_classifier     — EfficientNet B0 traffic sign type
         5. speed_limit_ocr     — EasyOCR numeric speed extraction
         6. lane_seg            — TwinLiteNet drivable area + lane lines
         7. perception_viz      — annotated overlay → /perception/annotated

       Mandatory args you may want to override:
         weights       path to YOLOv10 .pt model file
         calib_path    directory with calib_cam_to_cam.txt + calib_trial_Jan28.txt
         camera_topic  camera ROS topic
         lidar_topic   LiDAR PointCloud2 topic

       Optional gates (default on):
         lane_seg:=false          disable TwinLiteNet
         speed_limit_ocr:=false   disable EasyOCR
         perception_viz:=false    disable annotated overlay
  ════════════════════════════════════════════════════════════════════════ -->

  <!-- ── Model weights ─────────────────────────────────────────────────────── -->
  <arg name="weights"        default="$(find yolov10_ros)/models/yolov10-bdd-vanilla.pt"/>
  <arg name="light_weights"  default="$(find yolov10_ros)/models/efficientnet_b0_20260211_195116_light_cls.pth"/>
  <arg name="sign_weights"   default="$(find yolov10_ros)/models/efficientnet_b0_20260202_154542_sign_cls.pth"/>
  <arg name="lane_weights"   default="$(find yolov10_ros)/models/twinlitenet_best.pth"/>

  <!-- ── Inputs ────────────────────────────────────────────────────────────── -->
  <arg name="calib_path"   default="$(find yolov10_ros)/calib_files"/>
  <arg name="camera_topic" default="/camera_2/usb_cam_2/usb_cam_2_node/image_raw"/>
  <arg name="lidar_topic"  default="/ouster/points"/>

  <!-- ── Inference tuning ──────────────────────────────────────────────────── -->
  <arg name="confidence_threshold" default="0.5"/>
  <arg name="inference_size"       default="640"/>
  <arg name="device"               default="0"/>      <!-- "0" = cuda:0, "cpu" = CPU -->
  <arg name="half"                 default="false"/>  <!-- FP16, GPU only -->

  <!-- ── Time synchronisation tolerance (seconds) ──────────────────────────── -->
  <arg name="slop" default="0.1"/>

  <!-- ── Debug / visualisation ─────────────────────────────────────────────── -->
  <arg name="view_image"        default="false"/>
  <arg name="publish_annotated" default="false"/>

  <!-- ── Optional node gates ───────────────────────────────────────────────── -->
  <arg name="lane_seg"        default="true"/>
  <arg name="speed_limit_ocr" default="true"/>
  <arg name="perception_viz"  default="true"/>

  <!-- ── OCR tuning ────────────────────────────────────────────────────────── -->
  <arg name="ocr_roi_padding"          default="10"/>
  <arg name="ocr_min_crop_height"      default="64"/>
  <arg name="ocr_confidence_threshold" default="0.5"/>


  <!-- ── Node 1: YOLOv10 detector ──────────────────────────────────────── -->
  <node name="yolov10_detector"
        pkg="yolov10_ros"
        type="detector_node.py"
        output="screen"
        respawn="true"
        respawn_delay="3">

    <param name="weights"              value="$(arg weights)"/>
    <param name="confidence_threshold" value="$(arg confidence_threshold)"/>
    <param name="inference_size"       value="$(arg inference_size)"/>
    <param name="device"               value="$(arg device)"/>
    <param name="half"                 value="$(arg half)"/>

    <param name="input_image_topic"     value="$(arg camera_topic)"/>
    <param name="output_topic"          value="/yolov10/detections"/>
    <param name="output_image_topic"    value="/yolov10/image_raw"/>
    <param name="annotated_image_topic" value="/yolov10/annotated"/>

    <param name="view_image"        value="$(arg view_image)"/>
    <param name="publish_annotated" value="$(arg publish_annotated)"/>

  </node>

  <!-- ── Node 2: Perception fusion (LiDAR depth + scoring topics) ──────── -->
  <node name="perception_fusion"
        pkg="yolov10_ros"
        type="perception_fusion_node.py"
        output="screen"
        respawn="true"
        respawn_delay="3">

    <param name="calib_path"             value="$(arg calib_path)"/>
    <param name="input_detections_topic" value="/yolov10/detections"/>
    <param name="input_image_topic"      value="/yolov10/image_raw"/>
    <param name="input_pcl_topic"        value="$(arg lidar_topic)"/>
    <param name="slop"                   value="$(arg slop)"/>

  </node>

  <!-- ── Node 3: Traffic light classifier ─────────────────────────────── -->
  <node name="light_classifier"
        pkg="yolov10_ros"
        type="light_classifier_node.py"
        output="screen"
        respawn="true"
        respawn_delay="3">

    <param name="weights"         value="$(arg light_weights)"/>
    <param name="device"          value="$(arg device)"/>
    <param name="detection_topic" value="/yolov10/detections"/>
    <param name="image_topic"     value="/yolov10/image_raw"/>
    <param name="output_topic"    value="/perception/traffic_lights"/>

  </node>

  <!-- ── Node 4: Traffic sign classifier ──────────────────────────────── -->
  <node name="sign_classifier"
        pkg="yolov10_ros"
        type="sign_classifier_node.py"
        output="screen"
        respawn="true"
        respawn_delay="3">

    <param name="weights"         value="$(arg sign_weights)"/>
    <param name="device"          value="$(arg device)"/>
    <param name="detection_topic" value="/yolov10/detections"/>
    <param name="image_topic"     value="/yolov10/image_raw"/>
    <param name="output_topic"    value="/perception/traffic_signs"/>

  </node>

  <!-- ── Node 5: Speed limit OCR ──────────────────────────────────────── -->
  <node if="$(arg speed_limit_ocr)"
        name="speed_limit_ocr"
        pkg="yolov10_ros"
        type="speed_limit_ocr_node.py"
        output="screen"
        respawn="true"
        respawn_delay="3">

    <param name="sign_topic"               value="/perception/traffic_signs"/>
    <param name="image_topic"              value="/yolov10/image_raw"/>
    <param name="output_topic"             value="/perception/speed_limit"/>
    <param name="roi_padding"              value="$(arg ocr_roi_padding)"/>
    <param name="min_crop_height"          value="$(arg ocr_min_crop_height)"/>
    <param name="ocr_confidence_threshold" value="$(arg ocr_confidence_threshold)"/>
    <param name="device"                   value="$(arg device)"/>

  </node>

  <!-- ── Node 6: Lane segmentation ────────────────────────────────────── -->
  <node if="$(arg lane_seg)"
        name="lane_seg"
        pkg="yolov10_ros"
        type="lane_seg_node.py"
        output="screen"
        respawn="true"
        respawn_delay="3">

    <param name="weights"             value="$(arg lane_weights)"/>
    <param name="device"              value="$(arg device)"/>
    <param name="image_topic"         value="/yolov10/image_raw"/>
    <param name="drivable_area_topic" value="/perception/drivable_area"/>
    <param name="lane_lines_topic"    value="/perception/lane_lines"/>

  </node>

  <!-- ── Node 7: Perception visualizer ────────────────────────────────── -->
  <node if="$(arg perception_viz)"
        name="perception_viz"
        pkg="yolov10_ros"
        type="perception_viz_node.py"
        output="screen"
        respawn="true"
        respawn_delay="3">

    <param name="detection_topic" value="/yolov10/detections"/>
    <param name="image_topic"     value="/yolov10/image_raw"/>
    <param name="output_topic"    value="/perception/annotated"/>

  </node>

</launch>
